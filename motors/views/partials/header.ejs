<header class="site-header" role="banner">
  <div class="header-inner">
    <a href="/" class="site-title" aria-label="CSE Motors Home">CSE Motors</a>
    <div class="header-account">
      <% if (locals.loggedin) { %>
        <a href="/account/" class="account-link" title="Account Management">
          Welcome <%= locals.accountData.account_firstname %>
        </a>
        <a href="/account/logout" class="account-link account-logout">Logout</a>
      <% } else { %>
        <a href="/account/login" class="account-link">My Account</a>
      <% } %>
    </div>
  </div>
</header>
