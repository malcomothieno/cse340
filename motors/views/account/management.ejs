<section class="inv-management">
  <h1>Account Management</h1>

  <% if (notice && notice.length > 0) { %>
    <p class="notice <%= notice[0].includes('successfully') ? 'notice--success' : 'notice--error' %>">
      <%= notice[0] %>
    </p>
  <% } %>

  <h2>Welcome <%= locals.accountData.account_firstname %></h2>

  <div class="management-links">
    <a href="/account/update/<%= locals.accountData.account_id %>" class="btn-manage">
      Update Account Information
    </a>
    <a href="/wishlist" class="btn-manage">
      &#9825; My Wishlist
    </a>
  </div>

  <% if (locals.accountData.account_type === 'Employee' || locals.accountData.account_type === 'Admin') { %>
    <h3>Inventory Management</h3>
    <p><a href="/inv/" class="btn-manage">Manage Inventory</a></p>
  <% } %>
</section>
