<section class="error-section">
  <div class="error-inner">
    <p class="error-code"><%= status %></p>
    <h1 class="error-title">
      <% if (status === 404) { %>
        Page Not Found
      <% } else { %>
        Something Went Wrong
      <% } %>
    </h1>
    <p class="error-message"><%= message %></p>
    <a href="/" class="btn-own">Return Home</a>
  </div>
</section>