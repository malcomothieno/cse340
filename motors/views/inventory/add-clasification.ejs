<section class="form-section">
  <h1>Add New Classification</h1>

  <% if (notice && notice.length > 0) { %>
    <p class="notice notice--error"><%= notice[0] %></p>
  <% } %>

  <% if (errors && errors.length > 0) { %>
    <ul class="error-list" role="alert">
      <% errors.forEach(function(error) { %>
        <li><%= error.msg %></li>
      <% }) %>
    </ul>
  <% } %>

  <form
    action="/inv/add-classification"
    method="post"
    class="inv-form"
    novalidate
  >
    <div class="form-group">
      <label for="classification_name">Classification Name</label>
      <input
        type="text"
        id="classification_name"
        name="classification_name"
        value="<%= classification_name %>"
        required
        pattern="^[a-zA-Z0-9]+$"
        title="No spaces or special characters allowed"
        autocomplete="off"
      />
      <small class="form-hint">No spaces or special characters allowed (e.g. Sport, Electric, Custom)</small>
    </div>

    <button type="submit" class="btn-own">Add Classification</button>
    <a href="/inv/" class="btn-cancel">Cancel</a>
  </form>
</section>
