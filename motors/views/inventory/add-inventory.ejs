<section class="form-section">
  <h1>Add New Vehicle</h1>

  <% if (notice && notice.length > 0) { %>
    <p class="notice notice--error"><%= notice[0] %></p>
  <% } %>

  <% if (errors && errors.length > 0) { %>
    <ul class="error-list" role="alert">
      <% errors.forEach(function(error) { %>
        <li><%= error.msg %></li>
      <% }) %>
    </ul>
  <% } %>

  <form
    action="/inv/add-inventory"
    method="post"
    class="inv-form"
    novalidate
  >
    <div class="form-group">
      <label for="classification_id">Classification</label>
      <%- classificationList %>
    </div>

    <div class="form-row">
      <div class="form-group">
        <label for="inv_make">Make</label>
        <input
          type="text"
          id="inv_make"
          name="inv_make"
          value="<%= inv_make %>"
          required
          minlength="3"
          autocomplete="off"
        />
      </div>
      <div class="form-group">
        <label for="inv_model">Model</label>
        <input
          type="text"
          id="inv_model"
          name="inv_model"
          value="<%= inv_model %>"
          required
          minlength="3"
          autocomplete="off"
        />
      </div>
    </div>

    <div class="form-row">
      <div class="form-group">
        <label for="inv_year">Year</label>
        <input
          type="number"
          id="inv_year"
          name="inv_year"
          value="<%= inv_year %>"
          required
          min="1900"
          max="2099"
          placeholder="e.g. 2023"
        />
      </div>
      <div class="form-group">
        <label for="inv_color">Color</label>
        <input
          type="text"
          id="inv_color"
          name="inv_color"
          value="<%= inv_color %>"
          required
          autocomplete="off"
        />
      </div>
    </div>

    <div class="form-row">
      <div class="form-group">
        <label for="inv_price">Price ($)</label>
        <input
          type="number"
          id="inv_price"
          name="inv_price"
          value="<%= inv_price %>"
          required
          min="0"
          step="0.01"
          placeholder="e.g. 25000"
        />
      </div>
      <div class="form-group">
        <label for="inv_miles">Mileage</label>
        <input
          type="number"
          id="inv_miles"
          name="inv_miles"
          value="<%= inv_miles %>"
          required
          min="0"
          placeholder="e.g. 15000"
        />
      </div>
    </div>

    <div class="form-group">
      <label for="inv_description">Description</label>
      <textarea
        id="inv_description"
        name="inv_description"
        required
        rows="4"
      ><%= inv_description %></textarea>
    </div>

    <div class="form-group">
      <label for="inv_image">Image Path</label>
      <input
        type="text"
        id="inv_image"
        name="inv_image"
        value="<%= inv_image %>"
        required
        placeholder="/images/vehicles/vehicle-name.jpg"
      />
    </div>

    <div class="form-group">
      <label for="inv_thumbnail">Thumbnail Path</label>
      <input
        type="text"
        id="inv_thumbnail"
        name="inv_thumbnail"
        value="<%= inv_thumbnail %>"
        required
        placeholder="/images/vehicles/vehicle-name-tn.jpg"
      />
    </div>

    <div class="form-actions">
      <button type="submit" class="btn-own">Add Vehicle</button>
      <a href="/inv/" class="btn-cancel">Cancel</a>
    </div>
  </form>
</section>
