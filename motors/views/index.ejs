<%/* CSE Motors – Home View */%>

<section class="welcome-banner">
  <h1>Welcome to CSE Motors!</h1>
</section>

<section class="hero-vehicle" aria-label="Featured vehicle">
  <div class="hero-vehicle-inner">
    <div class="hero-vehicle-info">
      <h2 class="vehicle-name"><%= vehicle.name %></h2>
      <ul class="vehicle-features" role="list">
        <% vehicle.features.forEach(function(feature) { %>
        <li><%= feature %></li>
        <% }) %>
      </ul>
      <a href="<%= vehicle.link %>" class="btn-own">Own Today</a>
    </div>
    <div class="hero-vehicle-image">
      <img
        src="<%= vehicle.image %>"
        alt="<%= vehicle.name %> – featured vehicle at CSE Motors"
        width="320"
        height="200"
        loading="eager"
      />
    </div>
  </div>
</section>

<section class="lower-content">

  <div class="upgrades-section" aria-labelledby="upgrades-heading">
    <h2 id="upgrades-heading" class="section-label">Delorean Upgrades</h2>
    <ul class="upgrades-grid" role="list">
      <% upgrades.forEach(function(upgrade) { %>
      <li class="upgrade-item">
        <a href="<%= upgrade.link %>" class="upgrade-link">
          <img
            src="<%= upgrade.image %>"
            alt="<%= upgrade.name %>"
            class="upgrade-img"
            width="100"
            height="80"
            loading="lazy"
          />
          <span class="upgrade-name"><%= upgrade.name %></span>
        </a>
      </li>
      <% }) %>
    </ul>
  </div>

  <div class="reviews-section" aria-labelledby="reviews-heading">
    <h2 id="reviews-heading" class="section-label">DMC Delorean Reviews</h2>
    <ul class="reviews-list" role="list">
      <% reviews.forEach(function(review) { %>
      <li class="review-item">
        <p>&ldquo;<%= review.text %>&rdquo; (<%= review.rating %>)</p>
      </li>
      <% }) %>
    </ul>
  </div>

</section>
