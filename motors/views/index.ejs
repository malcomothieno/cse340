<div id="home-wrapper">

  <h1 id="home-heading">Welcome to CSE Motors!</h1>

  <!-- Hero: Featured Vehicle -->
  <section id="hero" aria-labelledby="hero-vehicle-name">
    <div id="hero-content">
      <h2 id="hero-vehicle-name">DMC Delorean</h2>
      <ul id="hero-features">
        <li>3 Cup holders</li>
        <li>Superman doors</li>
        <li>Fuzzy dice!</li>
      </ul>
      <a href="/inv/detail/1" class="btn-own">Own Today</a>
    </div>
    <div id="hero-image">
      <img
        src="/images/vehicles/delorean.jpg"
        alt="DMC Delorean with gull-wing doors open"
        width="600"
        height="400"
        loading="eager"
      />
    </div>
  </section>

  <!-- Bottom two-column section -->
  <div id="home-bottom">

    <!-- Upgrades -->
    <section id="upgrades" aria-labelledby="upgrades-heading">
      <h2 id="upgrades-heading">Delorean Upgrades</h2>
      <div id="upgrades-grid">
        <a href="/inv/upgrade/flux-capacitor" class="upgrade-card">
          <img src="/images/upgrades/flux-capacitor.jpg" alt="Flux Capacitor" width="120" height="120" loading="lazy" />
          <span>Flux Capacitor</span>
        </a>
        <a href="/inv/upgrade/flame-decals" class="upgrade-card">
          <img src="/images/upgrades/flame-decals.jpg" alt="Flame Decals" width="120" height="120" loading="lazy" />
          <span>Flame Decals</span>
        </a>
        <a href="/inv/upgrade/bumper-stickers" class="upgrade-card">
          <img src="/images/upgrades/bumper-stickers.jpg" alt="Bumper Stickers" width="120" height="120" loading="lazy" />
          <span>Bumper Stickers</span>
        </a>
        <a href="/inv/upgrade/hub-caps" class="upgrade-card">
          <img src="/images/upgrades/hub-caps.jpg" alt="Hub Caps" width="120" height="120" loading="lazy" />
          <span>Hub Caps</span>
        </a>
      </div>
    </section>

    <!-- Reviews -->
    <section id="reviews" aria-labelledby="reviews-heading">
      <h2 id="reviews-heading">DMC Delorean Reviews</h2>
      <ul id="reviews-list">
        <li>"So fast it's almost like traveling in time." (4/5)</li>
        <li>"Coolest ride on the road." (4/5)</li>
        <li>"I'm feeling McFly!" (5/5)</li>
        <li>"The most futuristic ride of our day." (4.5/5)</li>
        <li>"80's livin and I love it!" (5/5)</li>
      </ul>
    </section>

  </div><!-- end #home-bottom -->

</div><!-- end #home-wrapper -->
